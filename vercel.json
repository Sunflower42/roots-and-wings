{
  "crons": [{
    "path": "/api/push-send",
    "schedule": "0 12 * * 3"
  }],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "register.rootsandwingsindy.com" }],
      "destination": "/register.html"
    },
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "register.rootsandwingsindy.com" }],
      "destination": "/register.html"
    }
  ]
}
